# ─────────────────────────────────────────────────────────────────────────────
# Tax-Ready Invoice — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# A long random string for signing JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Supabase PostgreSQL connection string ─────────────────────────────────────
# Find your password in: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format (Session mode, port 5432 or Transaction mode port 6543)
#
# Format:
DATABASE_URL=postgresql://postgres.[project-ref]:[your-db-password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
#
# Your project ref is: lrijvnphwrtqgqgqrwic
# So your host is: db.lrijvnphwrtqgqgqrwic.supabase.co
# Example (direct connection):
#   DATABASE_URL=postgresql://postgres:[password]@db.lrijvnphwrtqgqgqrwic.supabase.co:5432/postgres
# Example (connection pooler — recommended for serverless/Render):
#   DATABASE_URL=postgresql://postgres.lrijvnphwrtqgqgqrwic:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Google Gemini API key (optional) ─────────────────────────────────────────
# Get yours free at https://makersuite.google.com/app/apikey
# If blank, AI category suggestion is skipped and defaults to "Other"
GEMINI_API_KEY=

# ── Stripe (for $9/month Pro subscription) ────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Create a $9/month recurring price in Stripe dashboard, paste the price ID here
STRIPE_PRICE_ID=price_...
# Webhook secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Your deployed app URL (no trailing slash)
APP_URL=https://tax-ready-invoice.onrender.com
